      "pattern": "(?<![\\u0600-\\u06FF])ترك(?![\\u0600-\\u06FF])",
      "flags": "g",
      "severity": "warn",
      "message": "MSA ترك (leave/left) — use خلّى (DZ)"
    },
    {
