      "pattern": "(?<![\\u0600-\\u06FF])حمل(?![\\u0600-\\u06FF])",
      "flags": "g",
      "severity": "warn",
      "message": "MSA حمل (carry/carried) — use رفد (DZ)"
    },
    {
      "id": "MSA-wajada",
      "pattern": "(?<![\\u0600-\\u06FF])وجد(?![\\u0600-\\u06FF])",
      "flags": "g",
      "severity": "warn",
      "message": "MSA وجد (found) — use لقا/لقى (DZ)"
    },
    {
      "id": "MSA-layl",
      "pattern": "(?<![\\u0600-\\u06FF])ليل(?![\\u0600-\\u06FF])",
      "flags": "g",
      "severity": "warn",
      "message": "MSA ليل (night) — use العشية (DZ Algiers)"
    },
    {
      "id": "MSA-thumma",
      "pattern": "(?<![\\u0600-\\u06FF])ثم(?![\\u0600-\\u06FF])",
      "flags": "g",
      "severity": "warn",
      "message": "MSA ثم (then) — use اومبعد/بعدها (DZ)"
    },
    {
      "id": "MSA-saala",
      "pattern": "(?<![\\u0600-\\u06FF])سأل(?![\\u0600-\\u06FF])",
      "flags": "g",
      "severity": "warn",
      "message": "REVIEW سأل (ask) — DZ NT uses it but سقسى is more colloquial"
    }
  ],
  "density_checks": [
    {
      "id": "DZ-bianna-density",
      "form": "بأن",
      "flags": "g",
      "vs": "بلي",
      "vsFlags": "g",
      "severity": "warn",
      "message": "MSA complementizer بأن used relative to DZ بلي — should be ~0"
    },
    {
      "id": "DZ-hadha-density",
      "form": "هذا|هذه|هؤلاء",
      "flags": "g",
      "vs": "هاد",
      "vsFlags": "g",
      "severity": "warn",
